rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Users can only read and write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /monitors/{monitorId} {
      // Monitors can be read/written by their owner
      allow read, write: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      
      // Sub-collections under a specific monitor (pings, incidents)
      match /{subPath=**} {
        // Need to check the parent monitor's user_id since the subcollections might not carry it directly
        // Usually handled securely via backend, but providing explicit denial or parent checks if direct access
        // Wait, for deep subcollections, using get() to check parent monitor owner:
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/monitors/$(monitorId)).data.user_id == request.auth.uid;
      }
    }
    match /alert_channels/{channelId} {
      allow read, write: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
    }
    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
