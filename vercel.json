{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "functions": {
    "server.ts": {
      "runtime": "vercel-node@latest",
      "includeFiles": ["server/**", "serviceAccount.json"]
    }
  }
}
